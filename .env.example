JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
PORT=4000
CORS_ORIGIN=http://localhost:9000
PUBLIC_BASE_URL=http://localhost:9000

# Frontend (packages/ryder-front/.env)
VITE_API_URL=http://localhost:4000/api
