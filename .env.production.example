# Copy to .env.production and edit before starting on Synology.
# PUBLIC_URL = the URL people use in a browser (no trailing slash).

# Generate: openssl rand -hex 32
JWT_SECRET=replace-with-a-long-random-secret

# Must match how you open the app in the browser (scheme + host + port).
# At home use LAN URL; for public HTTPS use your synology.me URL.
# Example: http://192.168.0.160:8080
PUBLIC_URL=http://192.168.0.160:8080

# Optional second origin if you use both LAN and HTTPS:
# CORS_ORIGIN=http://192.168.0.160:8080,https://ryder-collective.synology.me

# Port exposed on the NAS (web UI)
HTTP_PORT=8080

# MongoDB port on the NAS LAN IP (Compass: mongodb://192.168.0.160:27017/ryder)
# Leave unset or comment out in compose if you do not want Mongo reachable from the network.
MONGO_PORT=27017

JWT_EXPIRES_IN=7d
