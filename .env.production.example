# Copy to .env.production and edit before starting on Synology.
# PUBLIC_URL = the URL people use in a browser (no trailing slash).

# Generate: openssl rand -hex 32
JWT_SECRET=replace-with-a-long-random-secret

# Example: http://192.168.0.50:8080  or  https://ryder.yourname.synology.me
PUBLIC_URL=http://192.168.0.50:8080

# Port exposed on the NAS (web UI)
HTTP_PORT=8080

JWT_EXPIRES_IN=7d
